# Copy this file to .env (same folder) and fill values.
# IMPORTANT: Never commit .env (it is ignored by .gitignore)

# Hugging Face token (Inference Providers).
# Create a *fine-grained* token with permission: "Make calls to Inference Providers"
# https://huggingface.co/settings/tokens
HF_API_TOKEN=

# Optional: which hosted model to use (must be supported by your enabled providers)
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# Optional: request timeout (seconds)
HF_TIMEOUT_SECONDS=20

# Optional: prediction confidence threshold for 'uncertain'
PREDICTION_CONFIDENCE_THRESHOLD=0.50
